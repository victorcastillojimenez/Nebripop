# ==============================================================================
# Nebripop - Archivo de configuración de variables de entorno de ejemplo
# Copia este archivo a `.env` y rellena los valores reales para desarrollo local.
# ==============================================================================

# Puerto en el que escuchará el servidor de Nebripop
PORT=8080

# Nivel de logs para tracing (error, warn, info, debug, trace)
RUST_LOG=debug

# ------------------------------------------------------------------------------
# Base de datos (PostgreSQL 15 con PostGIS)
# ------------------------------------------------------------------------------
# Contraseña para el contenedor PostgreSQL (usado en docker-compose)
DB_PASSWORD=your_secure_postgres_password_here

# URL de conexión para SQLx/PostgreSQL
DATABASE_URL=postgres://postgres:your_secure_postgres_password_here@localhost:5432/nebripop

# ------------------------------------------------------------------------------
# Seguridad y Autenticación
# ------------------------------------------------------------------------------
# Cadena secreta larga y aleatoria (mínimo 32 caracteres) para firmar tokens JWT
JWT_SECRET=your_jwt_secret_token_at_least_32_characters_long

# ------------------------------------------------------------------------------
# Pasarela de pagos (Stripe)
# ------------------------------------------------------------------------------
# Clave secreta de Stripe (sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Secreto de firma del Webhook de Stripe (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ------------------------------------------------------------------------------
# Almacenamiento de Imágenes (Cloudinary)
# ------------------------------------------------------------------------------
# URL completa de Cloudinary (cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Nombre del cloud en Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Clave de API de Cloudinary
CLOUDINARY_API_KEY=your_api_key

# Secreto de API de Cloudinary
CLOUDINARY_API_SECRET=your_api_secret

# ------------------------------------------------------------------------------
# Motor de búsqueda (MeiliSearch)
# ------------------------------------------------------------------------------
# URL para el cliente de MeiliSearch
MEILISEARCH_URL=http://localhost:7700

# Clave maestra de MeiliSearch para autenticar peticiones (mínimo 16 bytes)
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key_at_least_16_bytes_long
